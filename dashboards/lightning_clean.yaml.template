title: Lightning
views:
  - title: Overview
    path: lightning-overview
    icon: mdi:car-electric
    cards:
      - type: markdown
        content: |
          # F-150 Lightning

      - type: custom:mushroom-chips-card
        alignment: center
        chips:
          - type: template
            entity: sensor.fordpass_{{VIN_LOWER}}_doorstatus
            icon: mdi:car-door
            icon_color: >
              {% set v = states('sensor.fordpass_{{VIN_LOWER}}_doorstatus') | lower %}
              {% if 'closed' in v or v in ['normal', 'ok'] %}
                green
              {% else %}
                red
              {% endif %}
            content: >
              Doors {{ states('sensor.fordpass_{{VIN_LOWER}}_doorstatus') }}

          - type: template
            entity: lock.fordpass_{{VIN_LOWER}}_doorlock
            icon: mdi:lock
            icon_color: >
              {% if is_state('lock.fordpass_{{VIN_LOWER}}_doorlock', 'locked') %}
                green
              {% else %}
                red
              {% endif %}
            content: >
              {{ states('lock.fordpass_{{VIN_LOWER}}_doorlock') | title }}

          - type: template
            entity: sensor.fordpass_{{VIN_LOWER}}_windowposition
            icon: mdi:window-closed-variant
            icon_color: >
              {% set v = states('sensor.fordpass_{{VIN_LOWER}}_windowposition') | lower %}
              {% if 'closed' in v or v in ['normal', 'ok'] %}
                green
              {% else %}
                red
              {% endif %}
            content: >
              Windows {{ states('sensor.fordpass_{{VIN_LOWER}}_windowposition') }}

          - type: template
            entity: sensor.fordpass_{{VIN_LOWER}}_elvehplug
            icon: mdi:ev-plug-type1
            icon_color: >
              {% set v = states('sensor.fordpass_{{VIN_LOWER}}_elvehplug') | lower %}
              {% if 'connected' in v or 'plugged' in v %}
                green
              {% else %}
                grey
              {% endif %}
            content: >
              {{ states('sensor.fordpass_{{VIN_LOWER}}_elvehplug') }}

      - type: grid
        title: Vehicle
        columns: 3
        square: false
        cards:
          - type: custom:mushroom-template-card
            entity: sensor.fordpass_{{VIN_LOWER}}_soc
            primary: Battery
            secondary: >
              {{ states('sensor.fordpass_{{VIN_LOWER}}_soc') | float(0) | round(0) | int }}%
            icon: mdi:battery-high
            icon_color: green
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.fordpass_{{VIN_LOWER}}_elveh
            primary: Range
            secondary: >
              {{ states('sensor.fordpass_{{VIN_LOWER}}_elveh') | float(0) | round(0) | int }} mi
            icon: mdi:map-marker-distance
            icon_color: blue
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.fordpass_{{VIN_LOWER}}_odometer
            primary: Odometer
            secondary: >
              {{ states('sensor.fordpass_{{VIN_LOWER}}_odometer') | float(0) | round(0) | int }} mi
            icon: mdi:counter
            icon_color: grey
            layout: vertical

      - type: gauge
        entity: sensor.fordpass_{{VIN_LOWER}}_soc
        name: Charge Level
        min: 0
        max: 100
        needle: true
        severity:
          green: 70
          yellow: 35
          red: 0

      - type: entities
        title: Charging
        show_header_toggle: false
        entities:
          - entity: sensor.fordpass_{{VIN_LOWER}}_elvehcharging
            name: Charging State
          - entity: sensor.fordpass_{{VIN_LOWER}}_elvehplug
            name: Plug Status
          - entity: sensor.lightning_current_charging_power
            name: Current Charging Power
          - entity: sensor.fordpass_{{VIN_LOWER}}_soc
            name: State of Charge
          - entity: select.fordpass_{{VIN_LOWER}}_elvehtargetcharge
            name: Target Charge Level

      - type: markdown
        content: |
          # Climate Settings

      - type: custom:mushroom-template-card
        entity: select.fordpass_{{VIN_LOWER}}_rcctemperature
        primary: Selected Climate Temperature
        secondary: >
          {% set v = states('select.fordpass_{{VIN_LOWER}}_rcctemperature') %}
          {% set map = {
            'lo':'LO',
            '16_0':'61°F','16_5':'62°F','17_0':'63°F','17_5':'64°F',
            '18_0':'64°F','18_5':'65°F','19_0':'66°F','19_5':'67°F',
            '20_0':'68°F','20_5':'69°F','21_0':'70°F','21_5':'71°F',
            '22_0':'72°F','22_5':'73°F','23_0':'73°F','23_5':'74°F',
            '24_0':'75°F','24_5':'76°F','25_0':'77°F','25_5':'78°F',
            '26_0':'79°F','26_5':'80°F','27_0':'81°F','27_5':'82°F',
            '28_0':'82°F','28_5':'83°F','29_0':'84°F','30_0':'86°F',
            'hi':'HI'
          } %}
          {{ map.get(v, v) }}
        icon: mdi:thermostat
        icon_color: orange
        layout: horizontal





      - type: custom:lightning-temp-slider-card
        title: Temperature
        entity: input_number.lightning_remote_climate_temp_f
        min: 60
        max: 86
        step: 1
      - type: grid
        title: Remote Climate Controls
        columns: 2
        square: false
        cards:
          - type: custom:button-card
            entity: switch.fordpass_{{VIN_LOWER}}_ignition
            name: Climate Power
            icon: mdi:power
            show_label: true
            label: >
              [[[
                const v = states['switch.fordpass_{{VIN_LOWER}}_ignition']?.state;
                return v === 'on' ? 'On' : 'Off';
              ]]]
            tap_action:
              action: call-service
              service: script.turn_on
              target:
                entity_id: script.lightning_toggle_remote_climate
            state:
              - value: "on"
                color: green
              - value: "off"
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 26px
                - height: 26px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 15px
                - font-weight: 800
                - padding-top: 6px

          - type: custom:button-card
            entity: sensor.lightning_remote_climate_minutes_remaining_live
            name: Extend Time
            icon: mdi:timer-plus
            show_label: true
            label: >
              [[[
                const raw = states['sensor.lightning_remote_climate_minutes_remaining_live']?.state;
                const n = Number(raw);
                if (isNaN(n)) return 'Extend';
                return `${Math.round(n)} min left`;
              ]]]
            tap_action:
              action: call-service
              service: script.turn_on
              target:
                entity_id: script.lightning_extend_remote_climate_and_reset_countdown
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 26px
                - height: 26px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 15px
                - font-weight: 800
                - padding-top: 6px

          - type: custom:button-card
            entity: switch.fordpass_{{VIN_LOWER}}_rccdefrostfront
            name: Front Defrost
            icon: mdi:car-defrost-front
            show_label: true
            label: >
              [[[
                const v = states['switch.fordpass_{{VIN_LOWER}}_rccdefrostfront']?.state;
                return v === 'on' ? 'On' : 'Off';
              ]]]
            tap_action:
              action: call-service
              service: script.turn_on
              target:
                entity_id: script.lightning_toggle_front_defrost
            state:
              - value: "on"
                color: orange
              - value: "off"
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 26px
                - height: 26px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 15px
                - font-weight: 800
                - padding-top: 6px

          - type: custom:button-card
            entity: switch.fordpass_{{VIN_LOWER}}_rccdefrostrear
            name: Rear Defrost
            icon: mdi:car-defrost-rear
            show_label: true
            label: >
              [[[
                const v = states['switch.fordpass_{{VIN_LOWER}}_rccdefrostrear']?.state;
                return v === 'on' ? 'On' : 'Off';
              ]]]
            tap_action:
              action: call-service
              service: script.turn_on
              target:
                entity_id: script.lightning_toggle_rear_defrost
            state:
              - value: "on"
                color: orange
              - value: "off"
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 26px
                - height: 26px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 15px
                - font-weight: 800
                - padding-top: 6px

          - type: custom:button-card
            entity: switch.fordpass_{{VIN_LOWER}}_rccsteeringwheel
            name: Steering Heat
            icon: mdi:steering
            show_label: true
            label: >
              [[[
                const v = states['switch.fordpass_{{VIN_LOWER}}_rccsteeringwheel']?.state;
                return v === 'on' ? 'On' : 'Off';
              ]]]
            tap_action:
              action: call-service
              service: script.turn_on
              target:
                entity_id: script.lightning_toggle_heated_steering_wheel
            state:
              - value: "on"
                color: orange
              - value: "off"
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 26px
                - height: 26px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 15px
                - font-weight: 800
                - padding-top: 6px

      - type: grid
        title: Front Seats
        columns: 2
        square: false
        cards:
          - type: custom:button-card
            entity: input_select.lightning_front_left_seat_request
            name: Front Left Heat
            icon: mdi:car-seat-heater
            show_label: true
            label: >
              [[[
                const v = states['input_select.lightning_front_left_seat_request']?.state?.toLowerCase();
                if (v === 'heated1') return '●○○';
                if (v === 'heated2') return '●●○';
                if (v === 'heated3') return '●●●';
                return '○○○';
              ]]]
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.lightning_front_left_heat
            state:
              - value: heated1
                color: orange
              - value: heated2
                color: orange
              - value: heated3
                color: orange
              - operator: default
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 34px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 22px
                - font-weight: 900
                - letter-spacing: 2px
                - padding-top: 6px

          - type: custom:button-card
            entity: input_select.lightning_front_left_seat_request
            name: Front Left Cool
            icon: mdi:fan
            show_label: true
            label: >
              [[[
                const v = states['input_select.lightning_front_left_seat_request']?.state?.toLowerCase();
                if (v === 'cooled1') return '●○○';
                if (v === 'cooled2') return '●●○';
                if (v === 'cooled3') return '●●●';
                return '○○○';
              ]]]
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.lightning_front_left_cool
            state:
              - value: cooled1
                color: blue
              - value: cooled2
                color: blue
              - value: cooled3
                color: blue
              - operator: default
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 34px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 22px
                - font-weight: 900
                - letter-spacing: 2px
                - padding-top: 6px

          - type: custom:button-card
            entity: input_select.lightning_front_right_seat_request
            name: Front Right Heat
            icon: mdi:car-seat-heater
            show_label: true
            label: >
              [[[
                const v = states['input_select.lightning_front_right_seat_request']?.state?.toLowerCase();
                if (v === 'heated1') return '●○○';
                if (v === 'heated2') return '●●○';
                if (v === 'heated3') return '●●●';
                return '○○○';
              ]]]
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.lightning_front_right_heat
            state:
              - value: heated1
                color: orange
              - value: heated2
                color: orange
              - value: heated3
                color: orange
              - operator: default
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 34px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 22px
                - font-weight: 900
                - letter-spacing: 2px
                - padding-top: 6px

          - type: custom:button-card
            entity: input_select.lightning_front_right_seat_request
            name: Front Right Cool
            icon: mdi:fan
            show_label: true
            label: >
              [[[
                const v = states['input_select.lightning_front_right_seat_request']?.state?.toLowerCase();
                if (v === 'cooled1') return '●○○';
                if (v === 'cooled2') return '●●○';
                if (v === 'cooled3') return '●●●';
                return '○○○';
              ]]]
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.lightning_front_right_cool
            state:
              - value: cooled1
                color: blue
              - value: cooled2
                color: blue
              - value: cooled3
                color: blue
              - operator: default
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 34px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 22px
                - font-weight: 900
                - letter-spacing: 2px
                - padding-top: 6px

      - type: grid
        title: Rear Seats
        columns: 2
        square: false
        cards:
          - type: custom:button-card
            entity: input_select.lightning_rear_left_seat_request
            name: Rear Left Heat
            icon: mdi:car-seat-heater
            show_label: true
            label: >
              [[[
                const v = states['input_select.lightning_rear_left_seat_request']?.state?.toLowerCase();
                if (v === 'heated1') return '●○○';
                if (v === 'heated2') return '●●○';
                if (v === 'heated3') return '●●●';
                return '○○○';
              ]]]
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.lightning_rear_left_heat
            state:
              - value: heated1
                color: orange
              - value: heated2
                color: orange
              - value: heated3
                color: orange
              - operator: default
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 34px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 22px
                - font-weight: 900
                - letter-spacing: 2px
                - padding-top: 6px

          - type: custom:button-card
            entity: input_select.lightning_rear_right_seat_request
            name: Rear Right Heat
            icon: mdi:car-seat-heater
            show_label: true
            label: >
              [[[
                const v = states['input_select.lightning_rear_right_seat_request']?.state?.toLowerCase();
                if (v === 'heated1') return '●○○';
                if (v === 'heated2') return '●●○';
                if (v === 'heated3') return '●●●';
                return '○○○';
              ]]]
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.lightning_rear_right_heat
            state:
              - value: heated1
                color: orange
              - value: heated2
                color: orange
              - value: heated3
                color: orange
              - operator: default
                color: grey
            styles:
              card:
                - border-radius: 18px
                - padding: 12px
              icon:
                - width: 34px
              name:
                - font-weight: 700
                - font-size: 13px
              label:
                - font-size: 22px
                - font-weight: 900
                - letter-spacing: 2px
                - padding-top: 6px


      - type: map
        title: Truck Location
        entities:
          - entity: device_tracker.fordpass_{{VIN_LOWER}}_tracker
            name: F-150 Lightning
        hours_to_show: 0
        default_zoom: 16
        aspect_ratio: 16:9

      - type: grid
        title: Environment & Battery
        columns: 3
        square: false
        cards:
          - type: gauge
            entity: sensor.fordpass_{{VIN_LOWER}}_battery
            name: 12V Battery
            needle: true
            min: 0
            max: 100
            severity:
              red: 0
              yellow: 50
              green: 75

          - type: gauge
            entity: sensor.fordpass_{{VIN_LOWER}}_cabintemperature
            name: Cabin Temp
            needle: true
            min: 30
            max: 140
            severity:
              green: 30
              yellow: 85
              red: 105

          - type: gauge
            entity: sensor.fordpass_{{VIN_LOWER}}_outsidetemp
            name: Outside Temp
            needle: true
            min: 0
            max: 120
            severity:
              green: 32
              yellow: 85
              red: 100


      - type: grid
        title: Controls
        columns: 2
        square: false
        cards:
          - type: button
            entity: button.fordpass_{{VIN_LOWER}}_update_data
            name: Refresh FordPass Data
            icon: mdi:refresh
            show_state: false
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.fordpass_{{VIN_LOWER}}_update_data

          - type: button
            entity: button.fordpass_{{VIN_LOWER}}_hafshort
            name: Honk & Flash Short
            icon: mdi:bullhorn
            show_state: false
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.fordpass_{{VIN_LOWER}}_hafshort

  - title: Last Trip
    path: last-trip
    icon: mdi:road-variant
    cards:

      - type: markdown
        content: |
          # Last Trip

      - type: grid
        columns: 2
        square: false
        cards:
          - type: custom:mushroom-template-card
            entity: sensor.fordpass_{{VIN_LOWER}}_lastenergyconsumed
            primary: Distance
            secondary: >
              {% set miles = state_attr('sensor.fordpass_{{VIN_LOWER}}_lastenergyconsumed', 'tripDistanceTraveled') | float(0) %}
              {% if miles > 0 %}
                {{ miles | round(2) }} mi
              {% else %}
                Unknown
              {% endif %}
            icon: mdi:map-marker-distance
            icon_color: blue
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.fordpass_{{VIN_LOWER}}_lastenergyconsumed
            primary: Duration
            secondary: >
              {{ state_attr('sensor.fordpass_{{VIN_LOWER}}_lastenergyconsumed', 'tripDuration') or 'Unknown' }}
            icon: mdi:timer
            icon_color: grey
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.fordpass_{{VIN_LOWER}}_lastenergyconsumed
            primary: Trip Energy Used
            secondary: >
              {% set wh = states('sensor.fordpass_{{VIN_LOWER}}_lastenergyconsumed') | float(0) %}
              {% if wh > 0 %}
                {{ (wh / 1000) | round(3) }} kWh
              {% else %}
                Unknown
              {% endif %}
            icon: mdi:battery-minus
            icon_color: red
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.lightning_last_trip_efficiency
            primary: FordPass Calculated Efficiency
            secondary: >
              {{ states('sensor.lightning_last_trip_efficiency') | float(0) | round(2) }} mi/kWh
            icon: mdi:leaf
            icon_color: green
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.fordpass_{{VIN_LOWER}}_cabintemperature
            primary: Cabin Temp
            secondary: >
              {{ states('sensor.fordpass_{{VIN_LOWER}}_cabintemperature') | float(0) | round(1) }} °F
            icon: mdi:home-thermometer
            icon_color: orange
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.fordpass_{{VIN_LOWER}}_ignitionstatus
            primary: Ignition
            secondary: >
              {{ states('sensor.fordpass_{{VIN_LOWER}}_ignitionstatus') }}
            icon: mdi:power
            icon_color: grey
            layout: vertical

      - type: history-graph
        title: Ignition History
        hours_to_show: 24
        entities:
          - entity: sensor.fordpass_{{VIN_LOWER}}_ignitionstatus
            name: Ignition

  - title: Mileage
    path: lightning-mileage
    icon: mdi:speedometer
    cards:
      - type: markdown
        content: |
          # Mileage

      - type: grid
        columns: 2
        square: false
        cards:
          - type: custom:mushroom-template-card
            entity: sensor.lightning_miles_today
            primary: Today
            secondary: >
              {{ states('sensor.lightning_miles_today') | float(0) | round(2) }} mi
            icon: mdi:calendar-today
            icon_color: blue
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.lightning_miles_this_week
            primary: This Week
            secondary: >
              {{ states('sensor.lightning_miles_this_week') | float(0) | round(2) }} mi
            icon: mdi:calendar-week
            icon_color: blue
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.lightning_miles_this_month
            primary: This Month
            secondary: >
              {{ states('sensor.lightning_miles_this_month') | float(0) | round(2) }} mi
            icon: mdi:calendar-month
            icon_color: blue
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.lightning_miles_this_year
            primary: This Year
            secondary: >
              {{ states('sensor.lightning_miles_this_year') | float(0) | round(2) }} mi
            icon: mdi:calendar
            icon_color: blue
            layout: vertical

      - type: custom:apexcharts-card
        header:
          show: true
          title: Miles Per Day - Last 7 Days
          show_states: true
        graph_span: 7d
        span:
          end: day
        apex_config:
          chart:
            height: 280
          stroke:
            curve: smooth
          yaxis:
            decimalsInFloat: 1
        series:
          - entity: sensor.lightning_miles_today
            name: Miles
            type: line
            stroke_width: 3
            extend_to: false
            group_by:
              duration: 1d
              func: max

      - type: custom:apexcharts-card
        header:
          show: true
          title: Miles Per Week - Last Month
          show_states: true
        graph_span: 31d
        span:
          end: week
        apex_config:
          chart:
            height: 280
          stroke:
            curve: smooth
          yaxis:
            decimalsInFloat: 1
        series:
          - entity: sensor.lightning_miles_this_week
            name: Miles
            type: line
            stroke_width: 3
            extend_to: false
            group_by:
              duration: 1w
              func: max

  - title: Energy
    path: lightning-energy
    icon: mdi:lightning-bolt-circle
    cards:
      - type: markdown
        content: |
          # Energy & Charging

      - type: grid
        title: Charging Added
        columns: 2
        square: false
        cards:
          - type: custom:mushroom-template-card
            entity: sensor.lightning_energy_charged_today
            primary: Today
            secondary: >
              {{ states('sensor.lightning_energy_charged_today') | float(0) | round(2) }} kWh · ${{ states('sensor.lightning_energy_charged_today_cost') | float(0) | round(2) }}
            icon: mdi:battery-plus
            icon_color: green
            layout: vertical

          - type: custom:mushroom-template-card
            entity: sensor.lightning_energy_charged_this_week
            primary: This Week
            secondary: >
