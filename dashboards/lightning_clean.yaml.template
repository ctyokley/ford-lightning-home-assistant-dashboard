          {% set rows = state_attr('sensor.lightning_recent_charge_sessions', 'sessions') or [] %}

          {% if rows | count == 0 %}
          No charge sessions have been logged yet.
          {% else %}
          {% for r in rows %}
          **{{ loop.index }}. {{ r.category }}** — **{{ r.kwh }} kWh** — **${{ r.cost }}**  
          {{ r.timestamp }}  
          {{ r.location_name }} — {{ r.city }}, {{ r.state }}  
