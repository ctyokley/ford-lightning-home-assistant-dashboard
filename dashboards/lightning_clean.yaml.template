            entity: script.lightning_ledger_refresh_paged_sessions
            name: Refresh Table
            icon: mdi:refresh
            tap_action:
              action: call-service
              service: script.lightning_ledger_refresh_paged_sessions

      - type: markdown
        content: |
          ## Sessions

          {% set page = state_attr('sensor.lightning_ledger_paged_sessions', 'page') | int(1) %}
          {% set total_pages = state_attr('sensor.lightning_ledger_paged_sessions', 'total_pages') | int(1) %}
          {% set total_sessions = state_attr('sensor.lightning_ledger_paged_sessions', 'total_sessions') | int(0) %}
          {% set page_size = state_attr('sensor.lightning_ledger_paged_sessions', 'page_size') %}
          {% set rows = state_attr('sensor.lightning_ledger_paged_sessions', 'sessions') or [] %}

          **Page {{ page }} of {{ total_pages }}**  
          **Total Sessions:** {{ total_sessions }}  
          **Rows Per Page:** {{ page_size }}

          {% if rows | count == 0 %}
          No sessions to display.
          {% else %}
          {% for r in rows %}
          ### {{ loop.index }}. {{ r.category }} — {{ r.kwh }} kWh — ${{ r.cost }}

          **Date/Time:** {{ r.timestamp }}  
          **Location:** {{ r.location_name }} — {{ r.city }}, {{ r.state }}  
          **Rate:** ${{ r.rate }}/kWh  
          **Charger:** {{ r.charger_type }}  
          **Miles Added:** {{ r.miles_added }} mi  
          **SOC:** {{ r.start_soc | int }}% → {{ r.end_soc | int }}%  
          **Status:** {% if r.void == 'true' %}VOID{% else %}Active{% endif %}  
          **Session ID:**  
          `{{ r.session_id }}`

          ---
          {% endfor %}
          {% endif %}

      - type: markdown
        content: |
          ## Compact Table View

          {% set rows = state_attr('sensor.lightning_ledger_paged_sessions', 'sessions') or [] %}

          {% if rows | count == 0 %}
          No sessions to display.
          {% else %}
          | Date | Type | kWh | Cost | Status |
          |---|---:|---:|---:|---|
          {% for r in rows %}
          | {{ r.timestamp }} | {{ r.category }} | {{ r.kwh }} | ${{ r.cost }} | {% if r.void == 'true' %}VOID{% else %}Active{% endif %} |
          {% endfor %}
          {% endif %}

      - type: markdown
        content: |
          ## Load / Edit a Session

          To edit one of these rows, copy the Session ID and go to the **Charge Ledger** tab.

          Paste it into the session selector/edit field, then load it.

